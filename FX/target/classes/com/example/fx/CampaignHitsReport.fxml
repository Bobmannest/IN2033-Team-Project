<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #FFFFFF;" stylesheets="@../fx/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.reports.CampaignHitsReportController">

   <top>
      <VBox BorderPane.alignment="CENTER">

         <ToolBar prefHeight="40.0" prefWidth="900.0" styleClass="topToolbar">
            <items>
               <ImageView fitHeight="33.0" fitWidth="199.0">
                  <image><Image url="@../../../images/curatech.png" /></image>
               </ImageView>
               <Pane prefHeight="38.0" prefWidth="560.0" HBox.hgrow="ALWAYS" />
               <Button mnemonicParsing="false" onAction="#handleBasket" style="-fx-font-weight: bold;" styleClass="BasketButton" text="Basket">
                  <graphic>
                     <ImageView fitHeight="30.0" fitWidth="30.0">
                        <image><Image url="@../../../images/cart.png" /></image>
                     </ImageView>
                  </graphic>
               </Button>
            </items>
         </ToolBar>

         <ToolBar prefHeight="40.0" prefWidth="900.0" styleClass="bottomToolbar">
            <items>
               <Button mnemonicParsing="false" onAction="#handleHome" styleClass="topButton">
                  <graphic>
                     <ImageView fitHeight="25.0" fitWidth="25.0">
                        <image><Image url="@../../../images/home.png" /></image>
                     </ImageView>
                  </graphic>
               </Button>
               <Button mnemonicParsing="false" onAction="#handleCatalogue" prefHeight="33.0" styleClass="topButton" text="Catalogue" />
               <Button mnemonicParsing="false" onAction="#handleActivePromotions" prefHeight="33.0" styleClass="topButton" text="Active Promotions" />
               <Button mnemonicParsing="false" onAction="#handleCreatePromotion" prefHeight="33.0" styleClass="topButton" text="Create Promotion" />
               <Button mnemonicParsing="false" onAction="#handleManagePromotions" prefHeight="33.0" styleClass="topButton" text="Manage Promotions" />
               <Button mnemonicParsing="false" onAction="#handleOrders" prefHeight="33.0" styleClass="topButton" text="Orders" />
               <Button mnemonicParsing="false" onAction="#handleAccount" prefHeight="33.0" styleClass="topButton" text="Account" />
               <Button mnemonicParsing="false" onAction="#handleReports" prefHeight="33.0" style="-fx-font-weight: bold; -fx-border-color: #1a7a4a; -fx-border-radius: 3; -fx-background-color: #c0ffc0;" styleClass="topButton" text="Reports" />
               <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="33.0" styleClass="topButton" text="Logout" />
            </items>
         </ToolBar>

         <VBox spacing="12">
            <padding><Insets bottom="0.0" left="24.0" right="24.0" top="16.0" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
               <ComboBox fx:id="campaignCombo" prefWidth="400.0" promptText="Select a campaign…" />
               <Button onAction="#handleGenerateReport" style="-fx-background-color: #1a7a4a; -fx-text-fill: white; -fx-font-weight: bold;" text="Generate Report" />
               <Button onAction="#handlePrint" style="-fx-background-color: #2c5f8a; -fx-text-fill: white; -fx-font-weight: bold;" text="🖨 Print" />
               <Button onAction="#handleReports" style="-fx-background-color: #888888; -fx-text-fill: white; -fx-font-weight: bold;" text="← Back to Reports" />
            </HBox>

            <Line endX="840.0" startX="-100.0" />

         </VBox>

         <VBox fx:id="printableArea" prefWidth="900.0" spacing="12">
            <padding><Insets bottom="20.0" left="24.0" right="24.0" top="8.0" /></padding>

            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-weight: bold; -fx-font-style: italic;" text="Customer Campaign Engagement Report">
               <font><Font name="Microsoft Sans Serif" size="22.0" /></font>
            </Text>
            <Line endX="840.0" startX="-100.0" />

            <VBox fx:id="headerBox" managed="false" spacing="4" visible="false">
               <HBox>
                  <VBox spacing="4" HBox.hgrow="ALWAYS">
                     <Label fx:id="lblCampaignId" style="-fx-font-weight: bold; -fx-font-size: 13px;" text="" />
                     <Label fx:id="lblCampaignDesc" style="-fx-font-size: 12px;" text="" />
                     <Label fx:id="lblStartDate" style="-fx-font-size: 12px;" text="" />
                     <Label fx:id="lblEndDate" style="-fx-font-size: 12px;" text="" />
                  </VBox>
                  <VBox alignment="TOP_RIGHT" style="-fx-font-size: 12px;">
                     <Label text="Cosymed Ltd.," />
                     <Label text="27 Sainsbury Close," />
                     <Label text="3, High Level Drive," />
                     <Label text="Sydenham," />
                     <Label text="SE26 3ET" />
                     <Label text="Phone: 0208 778 0124" />
                     <Label text="Fax: 0208 778 0125" />
                  </VBox>
               </HBox>
               <Label fx:id="lblGeneratedDate" style="-fx-font-size: 11px; -fx-text-fill: #666;" text="" />
            </VBox>

            <TableView fx:id="hitsTable" prefHeight="340.0" prefWidth="852.0" style="-fx-font-size: 13px;">
               <columns>
                  <TableColumn fx:id="colCounterId" prefWidth="110" text="Counter ID" />
                  <TableColumn fx:id="colDescription" prefWidth="230" text="Counter Description" />
                  <TableColumn fx:id="colHits" prefWidth="100" text="Hits Count" />
                  <TableColumn fx:id="colPurchases" prefWidth="100" text="Purchases" />
                  <TableColumn fx:id="colConversion" prefWidth="300" text="Conversion Rate" />
               </columns>
               <placeholder>
                  <Label text="Select a campaign and click Generate Report." />
               </placeholder>
            </TableView>

            <Label fx:id="errorLabel" style="-fx-text-fill: red;" text="" />

         </VBox>
      </VBox>
   </top>

</BorderPane>
