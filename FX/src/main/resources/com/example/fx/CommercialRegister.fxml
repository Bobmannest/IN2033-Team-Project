<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<BorderPane prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: #000000;"
            xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.fx.CommercialRegisterController"
            stylesheets="@style.css">
   <center>
      <HBox prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: #ffffff;"
            BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
         </BorderPane.margin>
         <children>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        prefHeight="596.0" prefWidth="560.0"
                        style="-fx-background-color: transparent; -fx-background: transparent;"
                        HBox.hgrow="ALWAYS">
               <content>
                  <VBox prefWidth="530.0" spacing="0">
                     <HBox.margin>
                        <Insets bottom="6.0" left="25.0" right="25.0" top="6.0" />
                     </HBox.margin>
                     <children>

                        <TextFlow prefHeight="63.0" prefWidth="480.0">
                           <children>
                              <Text strokeType="OUTSIDE" strokeWidth="0.0"
                                    text="Commercial Account Application">
                                 <font><Font name="MS Reference Sans Serif" size="24.0" /></font>
                              </Text>
                           </children>
                           <VBox.margin><Insets top="3.0" bottom="4.0" /></VBox.margin>
                        </TextFlow>

                        <Label text="Company Name" style="-fx-font-size: 13px;">
                           <VBox.margin><Insets top="10.0" bottom="2.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="companyNameField" prefHeight="33.0" prefWidth="480.0"
                                   promptText="Enter company name"
                                   style="-fx-background-radius: 20; -fx-background-color: #f1fff1; -fx-border-radius: 20; -fx-border-color: #808080;">
                           <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </TextField>

                        <Label text="Companies House Registration Number" style="-fx-font-size: 13px;">
                           <VBox.margin><Insets bottom="2.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="companiesHouseField" prefHeight="33.0" prefWidth="480.0"
                                   promptText="Companies House Registration No. (8 characters)"
                                   style="-fx-background-radius: 20; -fx-background-color: #f1fff1; -fx-border-radius: 20; -fx-border-color: #808080;">
                           <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </TextField>

                        <Label text="Company Director Name(s)" style="-fx-font-size: 13px;">
                           <VBox.margin><Insets bottom="2.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="directorNameField" prefHeight="33.0" prefWidth="480.0"
                                   promptText="Enter director name(s)"
                                   style="-fx-background-radius: 20; -fx-background-color: #f1fff1; -fx-border-radius: 20; -fx-border-color: #808080;">
                           <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </TextField>

                        <Label text="Type of Business" style="-fx-font-size: 13px;">
                           <VBox.margin><Insets bottom="2.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="businessTypeField" prefHeight="33.0" prefWidth="480.0"
                                   promptText="Type of Business e.g. Pharmacy, Healthcare Retailer"
                                   style="-fx-background-radius: 20; -fx-background-color: #f1fff1; -fx-border-radius: 20; -fx-border-color: #808080;">
                           <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </TextField>

                        <Label text="Business Address" style="-fx-font-size: 13px;">
                           <VBox.margin><Insets bottom="2.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="addressField" prefHeight="33.0" prefWidth="480.0"
                                   promptText="Enter full business address"
                                   style="-fx-background-radius: 20; -fx-background-color: #f1fff1; -fx-border-radius: 20; -fx-border-color: #808080;">
                           <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        </TextField>

                        <Label text="Email Address" style="-fx-font-size: 13px;">
                           <VBox.margin><Insets bottom="2.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="emailField" prefHeight="33.0" prefWidth="480.0"
                                   promptText="Enter company email address"
                                   style="-fx-background-radius: 20; -fx-background-color: #f1fff1; -fx-border-radius: 20; -fx-border-color: #808080;">
                           <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </TextField>

                        <Label fx:id="statusLabel" maxWidth="480.0" wrapText="true">
                           <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                        </Label>

                        <Button onAction="#handleSubmit" prefHeight="35.0" prefWidth="480.0"
                                style="-fx-background-radius: 20;" styleClass="signin"
                                text="Submit Application">
                           <font><Font size="16.0" /></font>
                           <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                        </Button>

                        <Button onAction="#handleBack" prefHeight="35.0" prefWidth="480.0"
                                style="-fx-background-radius: 20;" styleClass="signin"
                                text="Back to Sign In">
                           <font><Font size="16.0" /></font>
                           <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                        </Button>

                     </children>
                  </VBox>
               </content>
            </ScrollPane>

            <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                  prefHeight="596.0" prefWidth="220.0"
                  style="-fx-background-color: #c0ffc0; -fx-background-radius: 20 0 0 20;"
                  HBox.hgrow="ALWAYS">
               <children>
                  <BorderPane prefHeight="596.0" prefWidth="220.0" VBox.vgrow="ALWAYS">
                     <center>
                        <ImageView fitHeight="33.0" fitWidth="199.0" BorderPane.alignment="CENTER">
                           <image><Image url="@../../../images/curatech.png" /></image>
                        </ImageView>
                     </center>
                  </BorderPane>
               </children>
            </VBox>

         </children>
      </HBox>
   </center>
</BorderPane>
